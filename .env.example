# RMS — Research Management Service
NODE_ENV=development
# Valid: debug, info, warn, error
LOG_LEVEL=info

# Qdrant (shared instance with GMS)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ollama (LLM + Embeddings)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_CHAT_MODEL=qwen3:8b

# RMS-specific model overrides (optional, fall back to OLLAMA_* above)
# RMS_OLLAMA_EMBEDDING_MODEL=
# RMS_OLLAMA_CHAT_MODEL=

# SearXNG
SEARXNG_API_BASE=http://localhost:8080

# Research cache freshness (days)
RMS_FRESHNESS_DAYS=7

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
